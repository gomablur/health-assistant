// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "HEALTH-ASSISTANT",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",

	"mounts": [
		"source=${localEnv:HOME}/workspace/.claudes/health-assistant,target=/home/node/.claude,type=bind"
	],

	"customizations": {
		"vscode": {
			"extensions": ["anthropic.claude-code"]
		}
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
	},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// `expo start` は起動時に React Native DevTools(Electron製)を裏で準備する。
	// これを動かすためにコンテナ側で2つ必要:
	//   1. apt パッケージ群 = Electron(Chromium)が要求する共有ライブラリ。ここで入れる。
	//      無いと「error while loading shared libraries: libnspr4.so」で失敗する
	//   2. ELECTRON_DISABLE_SANDBOX = Chromium の SUID sandbox はこのコンテナでは
	//      構成不可能なため無効化する(理由の詳細は scripts/expo-start.sh のコメント)。
	//      npm start 経由なら同スクリプトが設定するので、これは npx expo start を
	//      直接叩いたときの保険。
	"containerEnv": {
		"ELECTRON_DISABLE_SANDBOX": "1"
	},
	"postCreateCommand": "sudo apt-get update && sudo apt-get upgrade -y && sudo apt-get install -y libnss3 libnspr4 libatk1.0-0t64 libatk-bridge2.0-0t64 libatspi2.0-0t64 libcups2t64 libdbus-1-3 libgbm1 libgtk-3-0t64 libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libasound2t64",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}

{
  "expo": {
    "name": "けさのからだ",
    "slug": "kesa-no-karada",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kesanokarada",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.goma-b.kesanokarada",
      "infoPlist": {
        "NSHealthShareUsageDescription": "体重・歩数・睡眠・心拍などのヘルスデータを読み取り、トレンド分析と振り返りに使用します。データは端末内で処理されます。"
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.goma_b.kesanokarada",
      "permissions": [
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_RESTING_HEART_RATE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_BASAL_METABOLIC_RATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#e8724a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#e8724a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "体重・歩数・睡眠・心拍などのヘルスデータを読み取り、トレンド分析と振り返りに使用します。データは端末内で処理されます。",
          "NSHealthUpdateUsageDescription": false,
          "background": false
        }
      ],
      "react-native-health-connect",
      "./plugins/with-health-connect-permission-usage",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}

{
  "name": "health-assistant",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "start": "expo start",
    "start:usb": "expo start --localhost",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild:clean": "expo prebuild --clean",
    "device:ios": "expo run:ios --device",
    "device:android": "expo run:android --device",
    "device:android:usb": "expo run:android --device --no-bundler",
    "standalone:ios": "expo run:ios --device --configuration Release",
    "standalone:android": "expo run:android --device --variant release",
    "build:android-apk": "eas build -p android --profile preview"
  },
  "dependencies": {
    "@expo/ui": "~57.0.4",
    "@expo/vector-icons": "^15.0.2",
    "@kingstinct/react-native-healthkit": "^14.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.4",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-health-connect": "^3.5.3",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ],
    "moduleNameMapper": {
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
